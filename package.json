{
  "name": "viviendaencrisis",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "build:docs": "typst compile docs/memory/main.typ",
    "build:features": "typst compile docs/features/main.typ",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "overrides": {
      "wired-elements>roughjs": "4.3.1"
    }
  },
  "devDependencies": {
    "cz-conventional-changelog": "^3.3.0",
    "prettier": "^3.8.1",
    "turbo": "^2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
