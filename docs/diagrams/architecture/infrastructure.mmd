graph LR
    subgraph ci["CI/CD"]
        gha["GitHub Actions"]
    end

    subgraph scaleway["Scaleway"]
        frontend["Contenedor frontend<br/>(Next.js)"]
        api["Contenedor API<br/>(Hono)"]
        mongo[("MongoDB<br/>(Managed Database)")]
    end

    gha -->|despliegue| frontend
    gha -->|despliegue| api
    frontend -->|HTTP / REST| api
    api -->|conexión| mongo

    classDef cicd fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef host fill:#f1f5f9,stroke:#64748b,color:#0f172a
    classDef database fill:#d1fae5,stroke:#059669,color:#052e16

    class gha cicd
    class frontend,api host
    class mongo database
